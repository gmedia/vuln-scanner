# Environment variables for Vuln Scanner
# Copy this to .env and fill in values

# PostgreSQL
POSTGRES_DB=vuln_scanner
POSTGRES_USER=vuln_scanner
POSTGRES_PASSWORD=change_me_in_production

# Backend
DATABASE_URL=postgresql+asyncpg://vuln_scanner:change_me_in_production@postgres:5432/vuln_scanner
DATABASE_URL_SYNC=postgresql://vuln_scanner:change_me_in_production@postgres:5432/vuln_scanner
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# API — ⚠️  CHANGE THESE IN PRODUCTION
# Generate strong keys: python3 -c "import secrets; print(secrets.token_hex(32))"
API_KEY=dev-api-key-change-me
SECRET_KEY=dev-secret-key-change-me-in-production

# Comma-separated allowed CORS origins (frontend URLs)
# Default allows local dev servers + same-origin through nginx
CORS_ORIGINS=http://localhost:5173,http://localhost,http://localhost:8000

# CVE Lookup
OSV_BASE_URL=https://api.osv.dev/v1
NVD_API_KEY=  # optional fallback

# Mobile Scan
MOBSF_URL=  # optional MobSF integration
MAX_UPLOAD_SIZE_MB=500

# Frontend (empty = relative path through nginx, same-origin)
# VITE_API_URL=http://localhost:8000
# VITE_WS_URL=ws://localhost:8000
# VITE_API_KEY=${API_KEY:-dev-api-key-change-me}
